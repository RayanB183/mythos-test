# ── Firebase (client SDK) ──
# OPTIONAL: the production Firebase web config is baked into
# lib/firebase/client.ts (it's public by design). Only set these to
# override it, e.g. to point a staging deploy at another project.
# NEXT_PUBLIC_FIREBASE_API_KEY=
# NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
# NEXT_PUBLIC_FIREBASE_PROJECT_ID=
# NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
# NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
# NEXT_PUBLIC_FIREBASE_APP_ID=
# NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=

# ── Firebase Admin (server only — SECRET) ──
# Required for Stripe billing. Firebase console → Project settings →
# Service accounts → Generate new private key.
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines, wrapped in quotes
FIREBASE_PRIVATE_KEY=""

# ── Stripe (server only — SECRET) ──
# Until these are set, the app runs fine and the upgrade button shows
# "Payments aren't enabled yet".
# Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe dashboard → Products → your Pro product → monthly price ID (price_...)
STRIPE_PRO_PRICE_ID=

# ── App ──
# OPTIONAL: base URL for Stripe redirects. Defaults to the request origin.
# NEXT_PUBLIC_APP_URL=https://mythos-test.vercel.app

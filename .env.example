# ── Firebase (client SDK — safe to expose, but still keep out of git) ──
# Firebase console → Project settings → General → Your apps → Web app
NEXT_PUBLIC_FIREBASE_API_KEY=
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=
NEXT_PUBLIC_FIREBASE_PROJECT_ID=
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=
NEXT_PUBLIC_FIREBASE_APP_ID=

# ── Firebase Admin (server only — SECRET) ──
# Firebase console → Project settings → Service accounts → Generate new private key
FIREBASE_CLIENT_EMAIL=
# Paste the private key with literal \n for newlines, wrapped in quotes
FIREBASE_PRIVATE_KEY=""

# ── Stripe (server only — SECRET) ──
# Stripe dashboard → Developers → API keys
STRIPE_SECRET_KEY=
# Stripe dashboard → Developers → Webhooks → your endpoint → Signing secret
STRIPE_WEBHOOK_SECRET=
# Stripe dashboard → Products → your Pro product → monthly price ID (price_...)
STRIPE_PRO_PRICE_ID=

# ── App ──
# Base URL used for Stripe redirect URLs (no trailing slash)
NEXT_PUBLIC_APP_URL=http://localhost:3000
